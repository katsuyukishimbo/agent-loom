# LLM provider keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Embeddings (defaults to OpenAI text-embedding-3-small if OPENAI_API_KEY is set,
# otherwise falls back to local sentence-transformers)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Storage
DATABASE_URL=postgresql+psycopg://agent_loom:agent_loom@localhost:5434/agent_loom
# Set to sqlite:///./agent_loom.db for the no-pgvector dev path

# Model routing defaults (can be overridden per run)
PLANNER_MODEL=claude-opus-4-7
GENERATOR_MODEL=claude-haiku-4-5
VERIFIER_MODEL=claude-sonnet-4-6
JUDGE_MODEL=gpt-5.5

# Budgets
DEFAULT_MAX_COST_PER_RUN_USD=2.00
DEFAULT_MAX_LLM_CALLS_PER_RUN=50

# Telemetry
LOG_LEVEL=INFO
TRACE_DIR=./runs
